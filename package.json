{
  "name": "appliquei-billing",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint \"api/**/*.js\" \"scripts/**/*.js\" \"web/**/*.js\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"api/**/*.js\" \"scripts/**/*.js\" \"web/**/*.js\" \"**/*.{json,md,yml,yaml}\"",
    "format:check": "prettier --check \"api/**/*.js\" \"scripts/**/*.js\" \"web/**/*.js\"",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test \"test/**/*.test.js\"",
    "test:flows": "node scripts/test-subscription-flow.js && node scripts/test-referral-flow.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "optimize:assets": "node scripts/optimize-assets.js",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@sentry/browser": "^10.56.0",
    "@sentry/node": "^10.56.0",
    "firebase-admin": "^12.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.4",
    "sharp": "^0.35.1",
    "vite": "^5.4.21"
  },
  "lint-staged": {
    "*.{js,json,md,yml,yaml}": "prettier --write",
    "{api,scripts,web}/**/*.js": "eslint --fix"
  }
}
