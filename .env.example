# Asaas
ASAAS_API_KEY=
ASAAS_API_URL=https://api.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=

# Firebase Admin (Service Account JSON em base64)
# gcloud iam service-accounts keys create key.json --iam-account=... ; base64 -w0 key.json
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_PROJECT_ID=appliquei-prod

# BRAPI (cotações Renda Variável). Opcional — sem token usa endpoints free.
BRAPI_TOKEN=

# Vercel Cron auth (auto-injetado em produção quando configurado em Settings).
CRON_SECRET=
