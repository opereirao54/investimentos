# Asaas
ASAAS_API_KEY=
ASAAS_API_URL=https://api.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=

# Firebase Admin (Service Account JSON em base64)
# gcloud iam service-accounts keys create key.json --iam-account=... ; base64 -w0 key.json
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_PROJECT_ID=appliquei-prod

# BRAPI (cotações Renda Variável). Opcional — sem token usa endpoints free.
BRAPI_TOKEN=

# Vercel Cron auth (auto-injetado em produção quando configurado em Settings).
CRON_SECRET=

# Admin endpoints (api/admin/*). Token único usado no header
# `Authorization: Bearer <ADMIN_API_TOKEN>`. Deixe vazio para desabilitar
# (endpoints retornam 503 admin_disabled).
ADMIN_API_TOKEN=

# Sentry (Onda C — observabilidade).
# Lado API (Node): captura exceções não tratadas dos endpoints via wrapper
# em api/_lib/handler.js. Deixe vazio para desligar (no-op silencioso).
SENTRY_DSN=

# Lado browser: DSN injetado no HTML via build/deploy.
# Para Vercel, defina nas Project Settings → Environment Variables e
# substitua window.__APPLIQUEI_SENTRY_DSN__='' no HTML via deploy hook
# ou template.

# Email verification enforcement: 'true' bloqueia hard quem não verificou
# (requireVerifiedUser retorna 403). Deixe vazio em rollout soft.
EMAIL_VERIFY_ENFORCE=

# Rate-limit antifraude do /init: 'true' enforce 5/dia por IP + 3/mês
# por device. Deixe vazio para só logar (warning, sem bloquear).
ANTIFRAUD_INIT_ENABLED=

# Bloqueia referral quando indicador e indicado vêm do MESMO IP. Por
# default (vazio) só bloqueia mesmo device — IP pode dar falso positivo
# em NAT corporativo.
REFERRAL_BLOCK_SAME_IP=
