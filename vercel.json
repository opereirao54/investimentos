{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/", "destination": "/landing.html" },
    { "source": "/app", "destination": "/Appliquei_v13.0.html" },
    { "source": "/app/(.*)", "destination": "/Appliquei_v13.0.html" }
  ],
  "functions": {
    "api/**/*.js": { "memory": 256, "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
